generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subscription {
  id              String   @id @default(cuid())
  toolName        String
  departmentOwner String
  renewalDate     DateTime
  monthlyCost     Float
  status          String   // "Active" | "Expiring Soon" | "Expired" | "Cancelled"
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
